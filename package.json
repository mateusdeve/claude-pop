{
  "name": "claude-overlay",
  "version": "0.1.0",
  "description": "Floating macOS overlay for Claude Code — permissions, questions, session switching, and text input from a global hotkey",
  "main": "dist/main/index.js",
  "author": "Mateus Pires",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusdeve/claude-pop.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "overlay",
    "electron",
    "macos",
    "hooks",
    "cli"
  ],
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack --config webpack.renderer.js --mode development --watch",
    "dev": "npm run build:main && npm run build:renderer && electron .",
    "install-hooks": "npm run build:main && node dist/scripts/install-hooks.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "css-loader": "^7.1.0",
    "electron": "^33.0.0",
    "html-webpack-plugin": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.6.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}
